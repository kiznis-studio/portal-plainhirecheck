---
interface StateItem {
  state: string;
  state_name: string;
  licensing_required: number;
}

interface Props {
  states: StateItem[];
}

const { states } = Astro.props;
---

<div class="grid grid-cols-4 sm:grid-cols-6 md:grid-cols-8 lg:grid-cols-10 gap-1.5">
  {states.map(s => (
    <a
      href={`/state/${s.state.toLowerCase()}`}
      title={s.state_name}
      class={`group relative flex items-center justify-center rounded text-xs font-semibold h-9 transition-all hover:scale-105 hover:z-10 hover:shadow-md ${
        s.licensing_required
          ? 'bg-blue-100 text-blue-800 hover:bg-blue-200 dark:bg-blue-900/40 dark:text-blue-200 dark:hover:bg-blue-800/60'
          : 'bg-gray-100 text-gray-600 hover:bg-gray-200 dark:bg-gray-800 dark:text-gray-400 dark:hover:bg-gray-700'
      }`}
    >
      {s.state}
    </a>
  ))}
</div>

<div class="mt-3 flex items-center gap-4 text-xs text-[var(--color-muted)]">
  <span class="flex items-center gap-1.5">
    <span class="w-3 h-3 rounded bg-blue-200 dark:bg-blue-900/60 inline-block"></span>
    License Required
  </span>
  <span class="flex items-center gap-1.5">
    <span class="w-3 h-3 rounded bg-gray-200 dark:bg-gray-700 inline-block"></span>
    No State License
  </span>
</div>
