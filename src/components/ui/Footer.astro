---
const siteName = "PlainHireCheck";
const currentYear = new Date().getFullYear();

const quickLinks = [
  { href: '/states', label: 'All States' },
  { href: '/trades', label: 'All Trades' },
  { href: '/rankings', label: 'State Rankings' },
  { href: '/guides', label: 'Hiring Guides' },
];

const legal = [
  { href: '/about', label: 'About' },
  { href: '/privacy', label: 'Privacy Policy' },
  { href: '/terms', label: 'Terms of Use' },
  { href: '/contact', label: 'Contact' },
];
---

<footer class="border-t border-[var(--color-border)] bg-[var(--color-card)] mt-auto">
  <div class="container py-16 md:py-20">
    <div class="grid grid-cols-2 md:grid-cols-12 gap-8">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-5 lg:col-span-4">
        <div class="font-semibold text-lg mb-3 flex items-center gap-2">
          <span class="text-xl">✓</span>
          <span>{siteName}</span>
        </div>
        <p class="text-sm text-[var(--color-muted)] max-w-xs leading-relaxed">
          Free contractor license verification data for all 50 states. Know who you're hiring before you sign.
        </p>
        <p class="text-xs text-[var(--color-muted)] mt-3">
          Data from state licensing boards, NCSL, and NASCLA. Updated 2026.
        </p>
      </div>

      <!-- Spacer -->
      <div class="hidden md:block md:col-span-3 lg:col-span-4"></div>

      <!-- Quick Links -->
      <div class="col-span-1 md:col-span-2 lg:col-span-2">
        <h3 class="text-xs font-semibold text-[var(--color-foreground)] uppercase tracking-wider mb-4">Explore</h3>
        <ul class="space-y-2.5">
          {quickLinks.map(item => (
            <li>
              <a href={item.href} class="text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Legal -->
      <div class="col-span-1 md:col-span-2 lg:col-span-2">
        <h3 class="text-xs font-semibold text-[var(--color-foreground)] uppercase tracking-wider mb-4">Legal</h3>
        <ul class="space-y-2.5">
          {legal.map(item => (
            <li>
              <a href={item.href} class="text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Related Data Portals -->
    <div class="mt-8 pt-6 border-t border-[var(--color-border)]">
      <p class="text-sm font-medium text-[var(--color-muted)] mb-3">Related Data Portals</p>
      <div class="flex flex-wrap gap-x-4 gap-y-1">
        <a href="https://plainworker.com" target="_blank" rel="noopener" class="text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors">Workplace Safety</a>
        <a href="https://plainregwatch.com" target="_blank" rel="noopener" class="text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors">State Regulations</a>
        <a href="https://plainsafety.com" target="_blank" rel="noopener" class="text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors">Product Safety</a>
        <a href="https://plainrent.com" target="_blank" rel="noopener" class="text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors">Rental Data</a>
        <a href="https://plainrecalls.com" target="_blank" rel="noopener" class="text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors">Product Recalls</a>
      </div>
    </div>

    <!-- Bottom -->
    <div class="border-t border-[var(--color-border)] mt-8 pt-8 flex flex-col sm:flex-row justify-between items-center gap-3">
      <p class="text-sm text-[var(--color-muted)]">
        © {currentYear} {siteName}. All rights reserved.
      </p>
      <p class="text-xs text-[var(--color-muted)] text-center sm:text-right max-w-md">
        For informational purposes only. Always verify contractor credentials directly with your state's licensing board.
      </p>
    </div>
  </div>
</footer>
