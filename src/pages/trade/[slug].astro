---
import Base from '../../layouts/Base.astro';
import { getTrade, getRequirementsByTrade, getFAQs } from '../../lib/db';

export const prerender = false;

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/trades');

const db = (Astro.locals as any).runtime?.env?.DB;

const [tradeData, requirements, faqs] = await Promise.all([
  getTrade(db, slug),
  getRequirementsByTrade(db, slug),
  getFAQs(db, undefined, slug),
]);

if (!tradeData) return Astro.redirect('/trades', 301);

const licensed = requirements.filter(r => r.required);
const notLicensed = requirements.filter(r => !r.required);
const pct = Math.round((licensed.length / requirements.length) * 100);

const pageTitle = `${tradeData.trade_name} License Requirements — All 50 States`;
const pageDesc = `${tradeData.trade_name} license requirements across all 50 states. ${licensed.length} of ${requirements.length} states require a license. Compare exam, bond, and insurance requirements.`;
---

<Base
  title={`${pageTitle} — PlainHireCheck`}
  description={pageDesc}
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: 'Trades', href: '/trades' },
    { name: tradeData.trade_name }
  ]}
>
  <section class="py-10 md:py-14">
    <div class="container">
      <!-- Header -->
      <div class="max-w-3xl mb-8">
        <h1 class="text-3xl font-bold text-[var(--color-foreground)]">{tradeData.trade_name} License Requirements</h1>
        <p class="text-[var(--color-muted)] mt-2 text-lg">{tradeData.description}</p>

        <!-- Stats Bar -->
        <div class="mt-6 grid grid-cols-3 gap-4">
          <div class="text-center card py-4">
            <div class="text-2xl font-bold text-[var(--color-accent)]">{licensed.length}</div>
            <div class="text-xs text-[var(--color-muted)] mt-1">States Require License</div>
          </div>
          <div class="text-center card py-4">
            <div class="text-2xl font-bold text-[var(--color-accent)]">{pct}%</div>
            <div class="text-xs text-[var(--color-muted)] mt-1">of All Jurisdictions</div>
          </div>
          <div class="text-center card py-4">
            <div class="text-2xl font-bold text-amber-600 dark:text-amber-400">{notLicensed.length}</div>
            <div class="text-xs text-[var(--color-muted)] mt-1">No State License</div>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="lg:col-span-2 space-y-8">
          <!-- States Requiring License -->
          <div class="card">
            <div class="flex items-center justify-between mb-4">
              <h2 class="text-lg font-bold text-[var(--color-foreground)]">
                States Requiring a {tradeData.trade_name} License ({licensed.length})
              </h2>
            </div>
            <div class="overflow-x-auto">
              <table class="w-full text-sm">
                <thead>
                  <tr class="border-b border-[var(--color-border)] text-xs text-[var(--color-muted)] uppercase tracking-wide">
                    <th class="text-left py-2 pr-3 font-medium">State</th>
                    <th class="text-left py-2 pr-3 font-medium">License Type</th>
                    <th class="text-center py-2 px-2 font-medium">Exam</th>
                    <th class="text-center py-2 px-2 font-medium">Bond</th>
                    <th class="text-center py-2 px-2 font-medium">Insur.</th>
                    <th class="text-left py-2 pl-2 font-medium">Fee</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-[var(--color-border)]">
                  {licensed.map(r => (
                    <tr class="hover:bg-[var(--color-card)] transition-colors">
                      <td class="py-2.5 pr-3">
                        <a href={`/state/${r.state.toLowerCase()}/${slug}`} class="font-semibold text-[var(--color-accent)] hover:underline">
                          {r.state_name}
                        </a>
                      </td>
                      <td class="py-2.5 pr-3 text-xs text-[var(--color-muted)] max-w-[180px]">
                        <span class="line-clamp-1">{r.license_type || '—'}</span>
                      </td>
                      <td class="py-2.5 px-2 text-center">
                        {r.exam_required
                          ? <span class="text-amber-600 dark:text-amber-400 text-xs font-medium">Yes</span>
                          : <span class="text-[var(--color-muted)] text-xs">No</span>
                        }
                      </td>
                      <td class="py-2.5 px-2 text-center">
                        {r.bond_required
                          ? <span class="text-xs text-amber-600 dark:text-amber-400 font-medium">
                              {r.bond_amount ? `$${(r.bond_amount / 1000).toFixed(0)}K` : 'Yes'}
                            </span>
                          : <span class="text-[var(--color-muted)] text-xs">No</span>
                        }
                      </td>
                      <td class="py-2.5 px-2 text-center">
                        {r.insurance_required
                          ? <span class="text-xs text-amber-600 dark:text-amber-400 font-medium">
                              {r.insurance_min ? `$${(r.insurance_min / 1000).toFixed(0)}K` : 'Yes'}
                            </span>
                          : <span class="text-[var(--color-muted)] text-xs">No</span>
                        }
                      </td>
                      <td class="py-2.5 pl-2 text-xs text-[var(--color-muted)]">
                        {r.fee_range || '—'}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>

          <!-- States Without License -->
          {notLicensed.length > 0 && (
            <div class="card">
              <h2 class="text-lg font-bold text-[var(--color-foreground)] mb-4">
                States Without State {tradeData.trade_name} License ({notLicensed.length})
              </h2>
              <p class="text-sm text-[var(--color-muted)] mb-4">
                In these states, {tradeData.trade_name.toLowerCase()} contractors do not require a state license.
                Local permits and municipal registration may still apply.
              </p>
              <div class="flex flex-wrap gap-2">
                {notLicensed.map(r => (
                  <a
                    href={`/state/${r.state.toLowerCase()}/${slug}`}
                    class="text-xs px-3 py-1.5 rounded-full bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors font-medium"
                  >
                    {r.state_name}
                  </a>
                ))}
              </div>
            </div>
          )}

          <!-- FAQs -->
          {faqs.length > 0 && (
            <div class="rounded-lg border border-[var(--color-border)] bg-white dark:bg-gray-900 p-6">
              <h2 class="text-xl font-bold text-[var(--color-foreground)]">Frequently Asked Questions</h2>
              <div class="mt-4 divide-y divide-[var(--color-border)]">
                {faqs.map((faq, i) => (
                  <details class="group py-4" open={i === 0}>
                    <summary class="flex cursor-pointer items-center justify-between font-medium text-[var(--color-foreground)] [&::-webkit-details-marker]:hidden list-none">
                      {faq.question}
                      <svg class="h-5 w-5 shrink-0 text-[var(--color-muted)] transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                      </svg>
                    </summary>
                    <p class="mt-3 text-sm text-[var(--color-muted)] leading-relaxed">{faq.answer}</p>
                  </details>
                ))}
              </div>
            </div>
          )}
        </div>

        <!-- Sidebar -->
        <div class="space-y-6">
          <!-- Quick Stats -->
          <div class="card">
            <h3 class="font-bold text-[var(--color-foreground)] mb-4">Licensing Breakdown</h3>
            <div class="space-y-3">
              <div>
                <div class="flex justify-between text-sm mb-1">
                  <span class="text-[var(--color-muted)]">License required</span>
                  <span class="font-semibold text-teal-600 dark:text-teal-400">{licensed.length} states</span>
                </div>
                <div class="h-2 bg-gray-200 dark:bg-gray-700 rounded-full overflow-hidden">
                  <div class="h-full bg-teal-500 rounded-full" style={`width: ${pct}%`}></div>
                </div>
              </div>
              <div class="pt-2 text-xs text-[var(--color-muted)] space-y-1">
                <div class="flex justify-between">
                  <span>With exam requirement</span>
                  <span>{licensed.filter(r => r.exam_required).length} states</span>
                </div>
                <div class="flex justify-between">
                  <span>With bond requirement</span>
                  <span>{licensed.filter(r => r.bond_required).length} states</span>
                </div>
                <div class="flex justify-between">
                  <span>With insurance requirement</span>
                  <span>{licensed.filter(r => r.insurance_required).length} states</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Disclaimer -->
          <div class="bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-lg p-4">
            <p class="text-xs text-amber-800 dark:text-amber-300 leading-relaxed">
              <strong>Disclaimer:</strong> Requirements shown are from state licensing boards, NCSL, and NASCLA data.
              Always verify current requirements directly with your state's licensing board.
            </p>
          </div>

          <!-- Related Trades -->
          <div class="card">
            <h3 class="font-bold text-[var(--color-foreground)] mb-3">Explore Other Trades</h3>
            <a href="/trades" class="text-sm text-[var(--color-accent)] hover:underline">View all 20 trades →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  {faqs.length > 0 && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqs.map(faq => ({
        "@type": "Question",
        "name": faq.question,
        "acceptedAnswer": { "@type": "Answer", "text": faq.answer }
      }))
    })} />
  )}
</Base>
