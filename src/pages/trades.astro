---
import Base from '../layouts/Base.astro';
import TradeCard from '../components/ui/TradeCard.astro';
import { getAllTrades } from '../lib/db';

const db = (Astro.locals as any).runtime?.env?.DB;
const trades = await getAllTrades(db);

const critical = trades.filter(t => t.states_requiring_license >= 45);
const common = trades.filter(t => t.states_requiring_license >= 30 && t.states_requiring_license < 45);
const specialty = trades.filter(t => t.states_requiring_license < 30);
---

<Base
  title="Contractor License Requirements by Trade — PlainHireCheck"
  description={`License requirements for 20 contractor trades across all 50 states. See which trades require a license, exam, bond, and insurance requirements.`}
  breadcrumbs={[{ name: 'Home', href: '/' }, { name: 'All Trades' }]}
>
  <section class="py-10 md:py-14">
    <div class="container">
      <div class="max-w-3xl mb-8">
        <h1 class="text-3xl font-bold text-[var(--color-foreground)]">Contractor License Requirements by Trade</h1>
        <p class="text-[var(--color-muted)] mt-2 text-lg">
          20 trade types tracked across all 50 states and DC. Click any trade to compare state-by-state requirements.
        </p>
      </div>

      <!-- Critical Trades (45+) -->
      {critical.length > 0 && (
        <div class="mb-10">
          <div class="flex items-center gap-3 mb-4">
            <h2 class="text-xl font-bold text-[var(--color-foreground)]">Universally Licensed Trades</h2>
            <span class="text-xs font-medium bg-amber-100 dark:bg-amber-900/40 text-amber-700 dark:text-amber-300 px-2 py-0.5 rounded-full">
              45+ states require license
            </span>
          </div>
          <p class="text-sm text-[var(--color-muted)] mb-4">
            These trades require licensing in nearly all states due to safety regulations and code enforcement.
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
            {critical.map(trade => <TradeCard {...trade} />)}
          </div>
        </div>
      )}

      <!-- Commonly Licensed Trades (30-44) -->
      {common.length > 0 && (
        <div class="mb-10">
          <div class="flex items-center gap-3 mb-4">
            <h2 class="text-xl font-bold text-[var(--color-foreground)]">Commonly Licensed Trades</h2>
            <span class="text-xs font-medium bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300 px-2 py-0.5 rounded-full">
              30–44 states
            </span>
          </div>
          <p class="text-sm text-[var(--color-muted)] mb-4">
            Required in most states, though a handful have more permissive local rules.
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
            {common.map(trade => <TradeCard {...trade} />)}
          </div>
        </div>
      )}

      <!-- Specialty Trades (under 30) -->
      {specialty.length > 0 && (
        <div class="mb-10">
          <div class="flex items-center gap-3 mb-4">
            <h2 class="text-xl font-bold text-[var(--color-foreground)]">Selectively Licensed Trades</h2>
            <span class="text-xs font-medium bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 px-2 py-0.5 rounded-full">
              Under 30 states
            </span>
          </div>
          <p class="text-sm text-[var(--color-muted)] mb-4">
            Licensed in fewer states — always check your specific state's requirements.
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
            {specialty.map(trade => <TradeCard {...trade} />)}
          </div>
        </div>
      )}

      <div class="mt-6 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-lg p-4 max-w-3xl">
        <p class="text-sm text-amber-800 dark:text-amber-300">
          <strong>Note:</strong> "License required" indicates a state-level license is needed. Even where no state license exists,
          local permits and registrations may be required. Always verify with your local building department.
        </p>
      </div>
    </div>
  </section>
</Base>
