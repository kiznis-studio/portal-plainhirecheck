---
import Base from '../layouts/Base.astro';
import { getAllStates } from '../lib/db';

const db = (Astro.locals as any).runtime?.env?.DB;
const states = await getAllStates(db);

const licensed = states.filter(s => s.licensing_required);
const notLicensed = states.filter(s => !s.licensing_required);
---

<Base
  title="Contractor Licensing Requirements by State — PlainHireCheck"
  description={`Contractor licensing requirements for all 50 states and DC. Find your state's licensing board, verification link, and trade requirements.`}
  breadcrumbs={[{ name: 'Home', href: '/' }, { name: 'All States' }]}
>
  <section class="py-10 md:py-14">
    <div class="container">
      <div class="max-w-3xl mb-8">
        <h1 class="text-3xl font-bold text-[var(--color-foreground)]">Contractor Licensing by State</h1>
        <p class="text-[var(--color-muted)] mt-2 text-lg">
          {licensed.length} of 51 jurisdictions require state contractor licensing.
          {notLicensed.length} rely on county or municipal rules.
        </p>
      </div>

      <!-- States Requiring License -->
      <div class="mb-10">
        <h2 class="text-xl font-bold text-[var(--color-foreground)] mb-4 flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-blue-500 inline-block"></span>
          States with State Contractor Licensing ({licensed.length})
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
          {licensed.map(s => (
            <a
              href={`/state/${s.state.toLowerCase()}`}
              class="card hover:border-[var(--color-accent)] transition-all flex items-center justify-between group"
            >
              <div>
                <div class="font-semibold text-[var(--color-foreground)] group-hover:text-[var(--color-accent)] transition-colors">
                  {s.state_name}
                </div>
                <div class="text-xs text-[var(--color-muted)] mt-0.5">
                  {s.trades_licensed} trades licensed · {s.licensing_board_name?.split(' ').slice(0, 4).join(' ')}
                </div>
              </div>
              <div class="flex items-center gap-2">
                <span class="text-xs font-medium bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300 px-2 py-0.5 rounded-full">
                  {s.state}
                </span>
                <svg class="w-4 h-4 text-[var(--color-muted)] group-hover:text-[var(--color-accent)] transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </div>
            </a>
          ))}
        </div>
      </div>

      <!-- States Without State License -->
      <div>
        <h2 class="text-xl font-bold text-[var(--color-foreground)] mb-2 flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-gray-400 inline-block"></span>
          States Without State General Contractor License ({notLicensed.length})
        </h2>
        <p class="text-sm text-[var(--color-muted)] mb-4">
          These states handle contractor regulation at the county or municipal level, or only license specific specialty trades.
          Always check local requirements.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
          {notLicensed.map(s => (
            <a
              href={`/state/${s.state.toLowerCase()}`}
              class="card hover:border-[var(--color-accent)] transition-all flex items-center justify-between group opacity-80 hover:opacity-100"
            >
              <div>
                <div class="font-semibold text-[var(--color-foreground)] group-hover:text-[var(--color-accent)] transition-colors">
                  {s.state_name}
                </div>
                <div class="text-xs text-[var(--color-muted)] mt-0.5">
                  No state GC license · {s.trades_licensed} specialty trades licensed
                </div>
              </div>
              <span class="text-xs font-medium bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 px-2 py-0.5 rounded-full">
                {s.state}
              </span>
            </a>
          ))}
        </div>
      </div>

      <!-- Note -->
      <div class="mt-10 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-lg p-4 max-w-3xl">
        <p class="text-sm text-amber-800 dark:text-amber-300">
          <strong>Important:</strong> Even in states without a statewide contractor license, individual cities and counties often require registration.
          Always check with your local building department in addition to the state licensing board.
        </p>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Dataset",
    "name": "US State Contractor Licensing Requirements",
    "description": "Contractor licensing requirements, board links, and verification URLs for all 51 US jurisdictions",
    "url": "https://plainhirecheck.com/states",
    "creator": { "@type": "Organization", "name": "PlainHireCheck" },
    "license": "https://creativecommons.org/publicdomain/zero/1.0/",
    "distribution": { "@type": "DataDownload", "encodingFormat": "text/html" }
  })} />
</Base>
