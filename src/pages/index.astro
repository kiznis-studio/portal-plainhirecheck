---
import Base from '../layouts/Base.astro';
import StateMap from '../components/ui/StateMap.astro';
import TradeCard from '../components/ui/TradeCard.astro';
import { getAllStates, getAllTrades, getStateSummary, getConsumerTips, getFAQs } from '../lib/db';

const db = (Astro.locals as any).runtime?.env?.DB;
const [states, trades, summary, tips, faqs] = await Promise.all([
  getAllStates(db),
  getAllTrades(db),
  getStateSummary(db),
  getConsumerTips(db),
  getFAQs(db),
]);

const siteName = "PlainHireCheck";
const siteUrl = "https://plainhirecheck.com";
---

<Base
  title="PlainHireCheck — Contractor License Verification by State"
  description={`Verify your contractor's license before you hire. State-by-state licensing requirements for all 20 trades across all 50 states. Free, official data.`}
>
  <!-- Hero -->
  <section class="py-12 md:py-20 bg-gradient-to-b from-blue-50/50 to-transparent dark:from-blue-950/20">
    <div class="container">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300 text-sm font-medium px-3 py-1 rounded-full mb-4">
          <span>✓</span>
          <span>{summary.requiring} states require contractor licensing</span>
        </div>
        <h1 class="text-4xl md:text-5xl font-bold mb-4 text-[var(--color-foreground)]">
          Verify Your Contractor<br class="hidden sm:block" /> Before You Hire
        </h1>
        <p class="text-xl text-[var(--color-muted)] mb-8 max-w-2xl">
          Free contractor license verification data for all 50 states. Know the licensing requirements, bond amounts, and how to check credentials before signing any contract.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="/states" class="btn btn-primary px-6 py-3 text-base font-semibold">
            Find Your State →
          </a>
          <a href="/guides/how-to-verify-a-contractor-license" class="btn px-6 py-3 text-base font-semibold border border-[var(--color-border)] hover:bg-[var(--color-card)] transition-colors">
            How to Verify a License
          </a>
        </div>
        <p class="mt-6 text-sm text-[var(--color-muted)]">
          Data from state licensing boards, NCSL, and NASCLA. Always verify directly with your state's board.
        </p>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="border-y border-[var(--color-border)] bg-[var(--color-card)] py-6">
    <div class="container">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div>
          <div class="text-3xl font-bold text-[var(--color-accent)]">{summary.requiring}</div>
          <div class="text-sm text-[var(--color-muted)] mt-1">States with licensing</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-[var(--color-accent)]">20</div>
          <div class="text-sm text-[var(--color-muted)] mt-1">Trade types covered</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-[var(--color-accent)]">1,020</div>
          <div class="text-sm text-[var(--color-muted)] mt-1">State × trade requirements</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-[var(--color-accent)]">{summary.not_requiring}</div>
          <div class="text-sm text-[var(--color-muted)] mt-1">States without state license</div>
        </div>
      </div>
    </div>
  </section>

  <!-- State Map -->
  <section class="py-12 md:py-16">
    <div class="container">
      <div class="flex items-center justify-between mb-6">
        <div>
          <h2 class="text-2xl font-bold text-[var(--color-foreground)]">License Requirements by State</h2>
          <p class="text-[var(--color-muted)] mt-1">Click any state to see contractor licensing requirements</p>
        </div>
        <a href="/states" class="text-sm text-[var(--color-accent)] hover:underline font-medium">All States →</a>
      </div>
      <StateMap states={states} />
    </div>
  </section>

  <!-- Trades Grid -->
  <section class="py-12 md:py-16 bg-[var(--color-card)]/50">
    <div class="container">
      <div class="flex items-center justify-between mb-6">
        <div>
          <h2 class="text-2xl font-bold text-[var(--color-foreground)]">License Requirements by Trade</h2>
          <p class="text-[var(--color-muted)] mt-1">Click a trade to compare requirements across all states</p>
        </div>
        <a href="/trades" class="text-sm text-[var(--color-accent)] hover:underline font-medium">All Trades →</a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        {trades.slice(0, 8).map(trade => (
          <TradeCard {...trade} />
        ))}
      </div>
      <div class="mt-4 text-center">
        <a href="/trades" class="text-sm text-[var(--color-accent)] hover:underline">
          View all {trades.length} trades →
        </a>
      </div>
    </div>
  </section>

  <!-- Consumer Tips -->
  <section class="py-12 md:py-16">
    <div class="container">
      <h2 class="text-2xl font-bold text-[var(--color-foreground)] mb-2">Hiring Tips from Consumer Advocates</h2>
      <p class="text-[var(--color-muted)] mb-8">Protect yourself with these essential steps before and during any contractor project.</p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {tips.slice(0, 6).map((tip, i) => (
          <div class="card">
            <div class="flex items-start gap-3">
              <div class="w-7 h-7 rounded-full bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300 flex items-center justify-center text-sm font-bold shrink-0">
                {i + 1}
              </div>
              <div>
                <h3 class="font-semibold text-[var(--color-foreground)] text-sm">{tip.title}</h3>
                <p class="text-sm text-[var(--color-muted)] mt-1.5 leading-relaxed line-clamp-3">{tip.content}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Guides CTA -->
  <section class="py-12 md:py-16 bg-blue-50 dark:bg-blue-950/30">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-2xl font-bold text-[var(--color-foreground)] mb-3">Know Your Rights as a Homeowner</h2>
        <p class="text-[var(--color-muted)] mb-8">
          Our free guides cover everything from verifying licenses to handling contractor disputes and understanding bonds and insurance.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 max-w-xl mx-auto">
          <a href="/guides/how-to-verify-a-contractor-license" class="card text-left hover:border-[var(--color-accent)] transition-colors">
            <div class="text-lg mb-2">🔍</div>
            <h3 class="font-semibold text-sm text-[var(--color-foreground)]">How to Verify a Contractor's License</h3>
          </a>
          <a href="/guides/red-flags-when-hiring-a-contractor" class="card text-left hover:border-[var(--color-accent)] transition-colors">
            <div class="text-lg mb-2">🚩</div>
            <h3 class="font-semibold text-sm text-[var(--color-foreground)]">10 Red Flags When Hiring a Contractor</h3>
          </a>
          <a href="/guides/what-to-do-when-contractor-does-bad-work" class="card text-left hover:border-[var(--color-accent)] transition-colors">
            <div class="text-lg mb-2">⚠️</div>
            <h3 class="font-semibold text-sm text-[var(--color-foreground)]">What to Do When Work Goes Wrong</h3>
          </a>
          <a href="/guides/understanding-contractor-bonds-and-insurance" class="card text-left hover:border-[var(--color-accent)] transition-colors">
            <div class="text-lg mb-2">🛡️</div>
            <h3 class="font-semibold text-sm text-[var(--color-foreground)]">Understanding Bonds and Insurance</h3>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- YMYL Disclaimer -->
  <section class="py-8">
    <div class="container">
      <div class="max-w-3xl mx-auto bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-lg p-4">
        <p class="text-sm text-amber-800 dark:text-amber-300 leading-relaxed">
          <strong>Disclaimer:</strong> PlainHireCheck provides publicly available state licensing data for informational purposes only.
          Always verify contractor credentials directly with your state's licensing board before hiring.
          License requirements and fee amounts change — this data was last updated January 2026.
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-8 pb-16">
    <div class="container">
      <div class="max-w-3xl mx-auto rounded-lg border border-[var(--color-border)] bg-white dark:bg-gray-900 p-6">
        <h2 class="text-xl font-bold text-[var(--color-foreground)]">Frequently Asked Questions</h2>
        <div class="mt-4 divide-y divide-[var(--color-border)]">
          {faqs.slice(0, 6).map((faq, i) => (
            <details class="group py-4" open={i === 0}>
              <summary class="flex cursor-pointer items-center justify-between font-medium text-[var(--color-foreground)] [&::-webkit-details-marker]:hidden list-none">
                {faq.question}
                <svg class="h-5 w-5 shrink-0 text-[var(--color-muted)] transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <p class="mt-3 text-sm text-[var(--color-muted)] leading-relaxed">{faq.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "name": siteName,
        "url": siteUrl,
        "description": "Free contractor license verification data for all 50 states and 20 trades."
      },
      {
        "@type": "WebSite",
        "name": siteName,
        "url": siteUrl,
        "potentialAction": {
          "@type": "SearchAction",
          "target": { "@type": "EntryPoint", "urlTemplate": `${siteUrl}/states` },
          "query-input": "required name=search_term_string"
        }
      }
    ]
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.slice(0, 6).map(faq => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": { "@type": "Answer", "text": faq.answer }
    }))
  })} />
</Base>
