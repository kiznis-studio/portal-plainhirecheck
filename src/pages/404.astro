---
import Base from '../layouts/Base.astro';
---

<Base title="Page Not Found — PlainHireCheck" description="The page you're looking for doesn't exist.">
  <section class="py-16 md:py-24">
    <div class="max-w-xl mx-auto px-4 text-center">
      <p class="text-6xl font-bold text-[var(--color-muted)] mb-4">404</p>
      <h1 class="text-2xl font-bold text-[var(--color-foreground)] mb-4">Page Not Found</h1>
      <p class="text-[var(--color-muted)] mb-8">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a
          href="/"
          class="btn btn-primary px-6 py-3"
        >
          ← Back to Home
        </a>
        <a
          href="/states"
          class="btn px-6 py-3 border border-[var(--color-border)] hover:bg-[var(--color-card)] transition-colors"
        >
          Browse States
        </a>
      </div>
    </div>
  </section>
</Base>
